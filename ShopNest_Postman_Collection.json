{
  "info": {
    "name": "ShopNest MERN API",
    "description": "Full Postman integration referencing all active backend routes of ShopNest API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@shopnest.com\",\n    \"password\": \"password123\"\n}" },
            "url": {"raw": "http://localhost:5000/api/auth/register", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"admin@shopnest.com\",\n    \"password\": \"password123\"\n}" },
            "url": {"raw": "http://localhost:5000/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:5000/api/auth/users", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "users"]}
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:5000/api/products", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "products"]}
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:5000/api/orders/myorders", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "orders", "myorders"]}
          }
        }
      ]
    }
  ]
}
